{
  "entities": {
    "plan": {
      "title": "Plan",
      "description": "Subscription plans available in the system",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "promo_price": { "type": "number" },
        "is_promo": { "type": "boolean" },
        "promo_label": { "type": "string" },
        "site_limit": { "type": "integer" },
        "description": { "type": "string" },
        "duration_hours": { "type": "number" },
        "features": { 
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["id", "name", "price", "site_limit"]
    },
    "subscription": {
      "title": "Subscription",
      "description": "User subscription status",
      "type": "object",
      "properties": {
        "user_email": { "type": "string" },
        "plan_id": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive", "cancelled"] },
        "expires_at": { "type": "string", "format": "date-time" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["user_email", "plan_id", "status"]
    },
    "site": {
      "title": "WordPress Site",
      "description": "User's connected WordPress sites",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "user_email": { "type": "string" },
        "url": { "type": "string" },
        "username": { "type": "string" },
        "application_password": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "user_email", "url", "username", "application_password"]
    },
    "payment": {
      "title": "Payment",
      "description": "Payment transactions record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "user_email": { "type": "string" },
        "plan_id": { "type": "string" },
        "amount": { "type": "number" },
        "transaction_id": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "user_email", "plan_id", "amount", "transaction_id"]
    },
    "translation": {
      "title": "Translation",
      "description": "Internationalization strings for landing page",
      "type": "object",
      "properties": {
        "key": { "type": "string" },
        "lang": { "type": "string" },
        "value": { "type": "string" }
      },
      "required": ["key", "lang", "value"]
    },
    "setting": {
      "title": "Global Setting",
      "description": "System wide settings",
      "type": "object",
      "properties": {
        "key": { "type": "string" },
        "value": { "type": "string" }
      },
      "required": ["key", "value"]
    },
    "user_offer": {
      "title": "User Offer",
      "description": "Special offers or messages for users",
      "type": "object",
      "properties": {
        "user_email": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "status": { "type": "string", "enum": ["unread", "read"] },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["user_email", "title", "content"]
    },
    "user": {
      "title": "User Profile",
      "description": "Registered user profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "display_name": { "type": "string" },
        "photo_url": { "type": "string" },
        "last_login": { "type": "string", "format": "date-time" },
        "google_tag_id": { "type": "string" },
        "google_tag_script": { "type": "string" }
      },
      "required": ["uid", "email"]
    },
    "order": {
      "title": "WooCommerce Order",
      "description": "Transactional order data",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "order_number": { "type": "string" },
        "customer_name": { "type": "string" },
        "customer_email": { "type": "string" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "completed", "cancelled"] },
        "items_count": { "type": "integer" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "order_number", "total", "status", "customer_email"]
    },
    "customer": {
      "title": "WooCommerce Customer",
      "description": "Customer profile and stats",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "full_name": { "type": "string" },
        "email": { "type": "string" },
        "total_spend": { "type": "number" },
        "orders_count": { "type": "integer" },
        "last_order": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["active", "inactive"] }
      },
      "required": ["id", "email", "full_name"]
    },
    "addon": {
      "title": "Addon",
      "description": "One-time micro-purchase items",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "description": { "type": "string" },
        "icon": { "type": "string" }
      },
      "required": ["id", "name", "price"]
    },
    "message": {
      "title": "Message",
      "description": "In-app communication messages",
      "type": "object",
      "properties": {
        "sender_email": { "type": "string" },
        "sender_name": { "type": "string" },
        "recipient_email": { "type": "string" },
        "subject": { "type": "string" },
        "body": { "type": "string" },
        "status": { "type": "string", "enum": ["unread", "read", "archived"] },
        "created_at": { "type": "string", "format": "date-time" },
        "site_url": { "type": "string" }
      },
      "required": ["sender_email", "recipient_email", "subject", "body"]
    },
    "mailing_list": {
      "title": "Mailing List",
      "description": "Emailing subscription and contact lists",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "user_email": { "type": "string" },
        "contacts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "first_name": { "type": "string" },
              "last_name": { "type": "string" },
              "email": { "type": "string" }
            },
            "required": ["email"]
          }
        },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "user_email", "contacts"]
    },
    "support_ticket": {
      "title": "Support Ticket",
      "description": "User submit tickets for session or technical support",
      "type": "object",
      "properties": {
        "user_email": { "type": "string" },
        "subject": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string", "enum": ["bug", "suggestion", "connection", "other"] },
        "status": { "type": "string", "enum": ["new", "processing", "resolved"] },
        "active_tab": { "type": "string" },
        "site_url": { "type": "string" },
        "browser_info": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "admin_reply": { "type": "string" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "required": ["user_email", "subject", "description", "category", "status", "active_tab", "created_at"]
    },
    "marketing_keyword": {
      "title": "Marketing Keyword",
      "description": "Targeted marketing or SEO keyword definitions",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "keyword": { "type": "string" },
        "category": { "type": "string" },
        "match_type": { "type": "string", "enum": ["phrase", "exact", "negative"] },
        "is_negative": { "type": "boolean" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "keyword", "category", "match_type"]
    },
    "smtp_setting": {
      "title": "SMTP Setting",
      "description": "User SMTP server settings for sending emails",
      "type": "object",
      "properties": {
        "user_email": { "type": "string" },
        "host": { "type": "string" },
        "port": { "type": "number" },
        "secure": { "type": "integer" },
        "auth_user": { "type": "string" },
        "auth_pass": { "type": "string" },
        "from_name": { "type": "string" },
        "from_email": { "type": "string" },
        "provider_type": { "type": "string" },
        "resend_api_key": { "type": "string" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "required": ["user_email", "host", "port"]
    },
    "imap_setting": {
      "title": "IMAP Setting",
      "description": "User IMAP server settings for fetching emails",
      "type": "object",
      "properties": {
        "user_email": { "type": "string" },
        "host": { "type": "string" },
        "port": { "type": "number" },
        "secure": { "type": "integer" },
        "auth_user": { "type": "string" },
        "auth_pass": { "type": "string" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "required": ["user_email", "host", "port"]
    },
    "communication_rule": {
      "title": "Communication Rule",
      "description": "User defined email trigger triggers",
      "type": "object",
      "properties": {
        "id": { "type": "integer" },
        "user_email": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "trigger_key": { "type": "string" },
        "scope": { "type": "string" },
        "is_active": { "type": "integer" },
        "template_id": { "type": "integer" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["user_email", "name", "trigger_key", "template_id"]
    },
    "email_template": {
      "title": "Email Template",
      "description": "User defined email design templates",
      "type": "object",
      "properties": {
        "id": { "type": "integer" },
        "user_email": { "type": "string" },
        "name": { "type": "string" },
        "subject": { "type": "string" },
        "body_html": { "type": "string" },
        "category": { "type": "string" },
        "is_ai_generated": { "type": "integer" },
        "brand_color": { "type": "string" },
        "accent_color": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["user_email", "name", "subject", "body_html"]
    }
  },
  "firestore": {
    "/smtp_settings/{email}": {
      "schema": "smtp_setting",
      "description": "User SMTP credentials"
    },
    "/imap_settings/{email}": {
      "schema": "imap_setting",
      "description": "User IMAP credentials"
    },
    "/communication_rules/{ruleId}": {
      "schema": "communication_rule",
      "description": "User configured automation rules"
    },
    "/email_templates/{templateId}": {
      "schema": "email_template",
      "description": "Custom templates for emails"
    },
    "/support_tickets/{ticketId}": {
      "schema": "support_ticket",
      "description": "Collection of user technical support tickets"
    },
    "/users/{userId}": {
      "schema": "user",
      "description": "System users collection"
    },
    "/orders/{orderId}": {
      "schema": "order",
      "description": "WooCommerce orders collection"
    },
    "/customers/{customerId}": {
      "schema": "customer",
      "description": "WooCommerce customers collection"
    },
    "/addons/{addonId}": {
      "schema": "addon",
      "description": "Collection of one-time purchase addons"
    },
    "/plans/{planId}": {
      "schema": "plan",
      "description": "Collection of subscription plans"
    },
    "/subscriptions/{userId}": {
      "schema": "subscription",
      "description": "User subscription detail (doc ID is user ID)"
    },
    "/sites/{siteId}": {
      "schema": "site",
      "description": "All WordPress sites across users"
    },
    "/payments/{paymentId}": {
      "schema": "payment",
      "description": "History of all payment transactions"
    },
    "/translations/{translationId}": {
      "schema": "translation",
      "description": "UI translations"
    },
    "/settings/{settingId}": {
      "schema": "setting",
      "description": "System settings"
    },
    "/user_offers/{offerId}": {
      "schema": "user_offer",
      "description": "Special offers sent to users"
    },
    "/messages/{messageId}": {
      "schema": "message",
      "description": "Customer communication messages"
    },
    "/mailing_lists/{listId}": {
      "schema": "mailing_list",
      "description": "Collection of user-defined mailing lists"
    },
    "/marketing_keywords/{keywordId}": {
      "schema": "marketing_keyword",
      "description": "Targeted marketing and advertising keywords list"
    }
  }
}
